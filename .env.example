# Scraper Server Environment Variables

# Puerto del servidor
PORT=3001

# MongoDB Connection (tu Atlas connection string)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/technostore?retryWrites=true&w=majority
DB_NAME=technostore

# Scraper Configuration (credenciales de Jotakp)
SUPPLIER_URL=https://jotakp.dyndns.org
SUPPLIER_LOGIN_URL=http://jotakp.dyndns.org/loginext.aspx
SUPPLIER_EMAIL=20418216795
SUPPLIER_PASSWORD=123456

# Cloudinary (para subir imágenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_FOLDER=technostore